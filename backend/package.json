    "@types/express": "^4.17.17",
    "@types/dotenv": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.25.9",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3",
    "vitest": "^2.1.8"
  }
}
