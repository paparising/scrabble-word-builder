{
  "name": "scrabble-backend",
  "version": "1.0.0",
  "description": "Scrabble Word Builder Backend API",
  "main": "dist/index.js",
  "scripts": {
    "start": "npm run build && node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "node esbuild.config.js",
